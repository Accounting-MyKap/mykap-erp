{
  "version": 2,
  "buildCommand": "cd client && npm run vercel-build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install && cd client && npm install && cd ../api && npm install",
  "functions": {
    "api/src/server.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/src/server.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}